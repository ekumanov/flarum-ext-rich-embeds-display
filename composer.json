{
    "name": "ekumanov/flarum-ext-rich-embeds-display",
    "description": "Renders OpenGraph preview cards for plain links in Flarum 2.0 posts. SSRF-hardened server-side fetcher, queue-backed, with per-card dismiss controls and self-link short-circuit. Optionally migrates legacy kilowhat/rich-embeds 1.x data on first run.",
    "keywords": [
        "flarum",
        "extension",
        "rich-embeds",
        "opengraph"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "flarum/core": "^2.0",
        "php": "^8.2",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "authors": [
        {
            "name": "ekumanov",
            "email": "ekumanov@users.noreply.github.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Ekumanov\\RichEmbedsDisplay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ekumanov\\RichEmbedsDisplay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:unit": "phpunit --colors=always --testsuite=unit"
    },
    "extra": {
        "flarum-extension": {
            "title": "Rich Embeds",
            "category": "feature",
            "icon": {
                "name": "fas fa-link",
                "backgroundColor": "#6E5494",
                "color": "#fff"
            }
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
